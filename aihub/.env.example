# Copy this to .env and fill in values

# PostgreSQL connection string
# For Coolify: use internal service URL
DATABASE_URL="postgresql://aihub:your_password@your_postgres_host:5432/aihub"

# Generate with: openssl rand -base64 32
NEXTAUTH_SECRET="your_random_secret_here"

# Your server IP or domain (app runs on port 4200)
NEXTAUTH_URL="http://YOUR_SERVER_IP:4200"
